{
  "name": "ns-sentinel-1",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "turbo run check",
    "db:start": "./scripts/db-start.sh",
    "db:stop": "./scripts/db-stop.sh",
    "db:generate": "bunx drizzle-kit generate --config=packages/db/drizzle.config.ts",
    "db:push": "bunx drizzle-kit push --config=packages/db/drizzle.config.ts",
    "db:studio": "bunx drizzle-kit studio --config=packages/db/drizzle.config.ts",
    "db:seed:youtube-channel": "bun run --cwd packages/crawl-helpers seed:youtube-channel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:notion": "bun run --cwd packages/notion-read start",
    "test:gmail": "bun run --cwd packages/gmail-read start",
    "test:slack": "bun run --cwd packages/slack-read start",
    "test:youtube": "bun run --cwd packages/youtube-read start",
    "test:x": "bun run --cwd packages/x-read start"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  }
}
